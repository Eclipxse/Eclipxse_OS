#!/usr/bin/env bash
set -euo pipefail

marker="$HOME/.config/marishoku/welcome-v1.seen"
if [[ -f $marker ]]; then
  exit 0
fi

mkdir -p "$(dirname "$marker")"
touch "$marker"

# Compose the approved first-login scene with real applications. These launch
# only once; subsequent sessions stay exactly as the user left them.
if command -v dolphin >/dev/null 2>&1; then
  dolphin "$HOME" >/dev/null 2>&1 &
fi
if command -v konsole >/dev/null 2>&1; then
  konsole --profile MARISHOKU -e bash -lc 'fastfetch; exec bash -l' \
    >/dev/null 2>&1 &
fi
exec marishoku-center --page welcome
